# ── 凭据 / 密钥（绝对不能上传）──────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key

# ── 运行时数据：每次查询的玩家聊天 + AI 标注 ────────────
# 含玩家原文、IP 推断的国家、AI 评级，是敏感数据，不入库
history/
history_received/

# ── Python 字节码 / 缓存 ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class

# ── 虚拟环境 ────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── 测试 / 覆盖率 ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ── 编辑器 / 系统 ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Streamlit 临时配置 ──────────────────────────────────
.streamlit/secrets.toml

# ── 临时 / 日志 ─────────────────────────────────────────
*.log
*.tmp
*.bak
