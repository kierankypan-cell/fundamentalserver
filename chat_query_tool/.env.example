# ============================================================
# .env.example —— 复制为 .env 后填上真实值（.env 不入仓库）
#     cp .env.example .env
# ============================================================

# ── Kyuubi（公司数据仓库）────────────────────────────────
# 建议用 service account；避免每个用户走自己的 LDAP 账号
KYUUBI_USER=your_ldap_user
KYUUBI_PASSWORD=your_ldap_password

# 主机和端口有合理默认（见 db.py），一般不需要改
# KYUUBI_HOST=kyuubi.bi.moontontech.net
# KYUUBI_PORT=10009

# Kyuubi engine 类型，三选一：
#   JDBC       默认推荐，Kyuubi 服务端已把 JDBC engine 默认路由到公司 Presto，最快最稳
#   TRINO      Kyuubi 原生 Trino engine（要传 URL + user，麻烦）
#   SPARK_SQL  YARN 上拉 Spark 应用，启动慢，仅在 JDBC 不可用时回退
# KYUUBI_ENGINE_TYPE=JDBC

# Trino 集群地址（仅 KYUUBI_ENGINE_TYPE=TRINO 时生效，JDBC 模式不用关心）
# KYUUBI_TRINO_URL=http://172.31.38.63:9088
# KYUUBI_TRINO_CATALOG=hive

# 同时允许的最大查询用户数；超过后排队
# MAX_CONCURRENT_USERS=3

# ── Anthropic（Claude API）───────────────────────────────
# 公司代理给的 key
ANTHROPIC_API_KEY=sk-...

# 公司代理地址；走官方 api.anthropic.com 可删
ANTHROPIC_BASE_URL=https://llm.moontontech.net/
