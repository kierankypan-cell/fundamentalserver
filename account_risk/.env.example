# account_risk 配置 —— 复制为 .env 后填入真实值（.env 不入仓库）
#   cp .env.example .env
# 重要：docker compose 的 env_file 只接受 KEY=VALUE 行，
#       .env 里不要放 ===== 之类的装饰线，否则容器会报 "invalid environment variable"。
# 本工具纯规则校验、无 LLM，只需要 Kyuubi 配置。
# db.py 优先读本目录 .env，缺失时回退读项目根 ../.env。

# 必填：Kyuubi（公司数据仓库）账号密码。建议用 service account。
KYUUBI_USER=your_ldap_user
KYUUBI_PASSWORD=your_ldap_password

# 以下均为可选（都有默认值，见 db.py），需要时取消注释并修改：
# KYUUBI_HOST=kyuubi.bi.moontontech.net
# KYUUBI_PORT=10009
# KYUUBI_ENGINE_TYPE=JDBC
# KYUUBI_TRINO_URL=http://172.31.38.63:9088
# KYUUBI_TRINO_CATALOG=hive
# MAX_CONCURRENT_USERS=3
