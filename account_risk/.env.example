# ============================================================
# .env.example —— 复制为 .env 后填上真实值（.env 不入仓库）
#     cp .env.example .env
# 本工具纯规则校验、无 LLM，因此只需要 Kyuubi 配置。
# 本目录 .env 优先；缺失时 db.py 会回退读项目根 ../.env。
# ============================================================

# ── Kyuubi（公司数据仓库）────────────────────────────────
# 建议用 service account；避免每个用户走自己的 LDAP 账号
KYUUBI_USER=your_ldap_user
KYUUBI_PASSWORD=your_ldap_password

# 主机和端口有合理默认（见 db.py），一般不需要改
# KYUUBI_HOST=kyuubi.bi.moontontech.net
# KYUUBI_PORT=10009

# Kyuubi engine 类型，三选一：JDBC（默认推荐）/ TRINO / SPARK_SQL
# KYUUBI_ENGINE_TYPE=JDBC

# Trino 集群地址（仅 KYUUBI_ENGINE_TYPE=TRINO 时生效）
# KYUUBI_TRINO_URL=http://172.31.38.63:9088
# KYUUBI_TRINO_CATALOG=hive

# 同时允许的最大查询用户数；超过后排队
# MAX_CONCURRENT_USERS=3
